         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy"
         xmlns="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#">

<owl:Ontology rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ni Superalloy Ontology</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ni-based superalloy ontology using an n-ary pattern for composition and mechanical properties. Quantities support exact values, ranges, inequalities and unit/scale strings. Variants represent different forms and processing conditions of the same base alloy. PropertySets group multiple measurements of the same property type (e.g., temperature-dependent data).</rdfs:comment>
  <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9.0.0</owl:versionInfo>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#hasComposition">
  <rdfs:domain rdf:resource="#NickelBasedSuperalloy"/>
  <rdfs:range rdf:resource="#Composition"/>
</owl:ObjectProperty>

