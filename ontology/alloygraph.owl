  <rdf:Description rdf:about="https://w3id.org/alloygraph/ont#ProcessingMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:label xml:lang="en">Processing Method</rdfs:label>
    <rdfs:comment xml:lang="en">The manufacturing or processing route applied to an alloy (e.g., wrought, cast).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/alloygraph/ont#GammaPrimePhase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/alloygraph/ont#Phase"/>
    <rdfs:label xml:lang="en">Gamma Prime Phase</rdfs:label>
    <rdfs:comment xml:lang="en">The ordered L1_2 gamma prime precipitate phase (Ni3Al-type).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/alloygraph/ont#TCPRiskModerate">
