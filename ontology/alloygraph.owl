    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:label xml:lang="en">estimated gamma prime vol%</rdfs:label>
    <rdfs:comment xml:lang="en">The estimated gamma prime volume fraction from the solubility-based model, in percent.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/alloygraph/ont#isApproximate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
