<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloys#"
     xml:base="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloys"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloys">
        <rdfs:comment xml:lang="en">Ni-based superalloy ontology using an n-ary pattern for composition and mechanical properties. Quantities support exact values, ranges, inequalities and unit/scale strings. No individuals included.</rdfs:comment>
        <rdfs:label xml:lang="en">Ni Superalloy Ontology</rdfs:label>
        <owl:versionInfo>7.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#element -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#element">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#CompositionEntry"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Element"/>
        <rdfs:label xml:lang="en">element</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasComponent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasComponent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Composition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#CompositionEntry"/>
        <rdfs:label xml:lang="en">has component</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasComposition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasComposition">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#NickelBasedSuperalloy"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Composition"/>
        <rdfs:label xml:lang="en">has composition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasMassFraction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasMassFraction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#CompositionEntry"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:label xml:lang="en">has mass fraction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasMeasurement -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasMeasurement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#NickelBasedSuperalloy"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Measurement"/>
        <rdfs:label xml:lang="en">has measurement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasQuantity -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasQuantity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Measurement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:label xml:lang="en">has quantity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#measures -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#measures">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Measurement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
        <rdfs:label xml:lang="en">measures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#isApproximate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#isApproximate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">is approximate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#isBalanceRemainder -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#isBalanceRemainder">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#CompositionEntry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True when the entry denotes &apos;Bal.&apos;; omit hasMassFraction in that case.</rdfs:comment>
        <rdfs:label xml:lang="en">is balance remainder</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#maxInclusive -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#maxInclusive">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">max inclusive</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#minInclusive -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#minInclusive">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">min inclusive</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#nominal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#nominal">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">nominal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#numericValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#numericValue">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">numeric value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#otherConstituents -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#otherConstituents">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Composition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Free-text for minor/trace additions if not modeled as separate entries.</rdfs:comment>
        <rdfs:label xml:lang="en">other constituents</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#tradeDesignation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#tradeDesignation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#NickelBasedSuperalloy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">trade designation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#unitSymbol -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#unitSymbol">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">e.g., &apos;wt%&apos;,&apos;%&apos;,&apos;MPa&apos;,&apos;GPa&apos;,&apos;HRB&apos;,&apos;HRC&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">unit/scale symbol</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#unsNumber -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#unsNumber">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#NickelBasedSuperalloy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">UNS number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Composition -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Composition">
        <rdfs:comment xml:lang="en">A composition record; contains multiple entries.</rdfs:comment>
        <rdfs:label xml:lang="en">Composition</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#CompositionEntry -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#CompositionEntry">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#element"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Element"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasMassFraction"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Binds an element (or grouped column like &apos;Nb+Ta&apos;) to its mass-fraction quantity. Balance supported.</rdfs:comment>
        <rdfs:label xml:lang="en">Composition Entry</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#ElasticModulus -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#ElasticModulus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
        <rdfs:label xml:lang="en">Elastic Modulus</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Element -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Element">
        <rdfs:comment xml:lang="en">Chemical element label used by the KG (e.g., Ni, Cr, Fe). Columns like &apos;Nb+Ta&apos; may be modeled as one Element resource.</rdfs:comment>
        <rdfs:label xml:lang="en">Element</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Elongation -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Elongation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
        <rdfs:label xml:lang="en">Elongation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Hardness -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Hardness">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
        <rdfs:label xml:lang="en">Hardness</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Measurement -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Measurement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#hasQuantity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#measures"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Links a superalloy to a property kind and a quantity (supports ranges via min/max).</rdfs:comment>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty">
        <rdfs:label xml:lang="en">Mechanical Property</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#NickelBasedSuperalloy -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#NickelBasedSuperalloy">
        <rdfs:comment xml:lang="en">Scope root class for all materials in this project.</rdfs:comment>
        <rdfs:label xml:lang="en">Nickel-Based Superalloy</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#Quantity">
        <rdfs:comment xml:lang="en">Numeric value with optional min/max/nominal and a unit/scale string. Supports exact values, ranges, ≥/≤, and &apos;~&apos; via isApproximate.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#TensileStrength -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#TensileStrength">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
        <rdfs:label xml:lang="en">Tensile Strength</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#YieldStrength -->

    <owl:Class rdf:about="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#YieldStrength">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/alexlecu/ontologies/nisuperalloy#MechanicalProperty"/>
        <rdfs:label xml:lang="en">Yield Strength</rdfs:label>
    </owl:Class>
</rdf:RDF>



